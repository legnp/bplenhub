rules_version = '2';

/**
 * BPlen HUB — Cloud Firestore Security Rules (Soberania de Dados 🛡️)
 * 
 * Regras fundamentais de proteção v3.
 * O Servidor (Admin SDK) ignora estas regras, permitindo governança total via Server Actions.
 * O Cliente (SDK Web) é restrito ao mínimo necessário para operação segura.
 */

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 🛡️ [Governança] Mapeamento de Autenticação
    // Apenas o próprio usuário pode ler seu mapeamento de UID -> Matrícula.
    match /_AuthMap/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; 
    }

    // 👥 [Usuários] Coleção Principal de Perfis
    // REGRA DE OURO 🛡️: Um usuário só pode ler seu PRÓPRIO perfil.
    match /User/{matricula} {
      allow read: if request.auth != null && (
        // Valida se o UID do solicitante autenticado é o dono desta matrícula no sistema
        get(/databases/$(database)/documents/_AuthMap/$(request.auth.uid)).data.matricula == matricula
      );
      allow write: if false; // Escrita exclusiva via Admin SDK / Server Actions

      // 🏗️ Sub-coleção de Permissões (Entitlements)
      // Mesma governança da coleção pai.
      match /User_Permissions/access {
        allow read: if request.auth != null && (
          get(/databases/$(database)/documents/_AuthMap/$(request.auth.uid)).data.matricula == matricula
        );
        allow write: if false; // Escrita soberana via Servidor
      }
      
      // 📚 Outras sub-coleções (Ex: Agenda, Forms, Mensagens)
      // Todas as subáreas seguem o princípio do dono da matrícula. 🔐
      match /{allSubcollections=**} {
        allow read: if request.auth != null && (
          get(/databases/$(database)/documents/_AuthMap/$(request.auth.uid)).data.matricula == matricula
        );
        allow write: if false;
      }
    }

    // 🔒 [Configurações] Global
    match /Settings/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // 🏷️ [Marketing] Produtos e Cupons
    match /products/{id} {
      allow read: if true;
      allow write: if false;
    }
    match /marketing_coupons/{id} {
      allow read: if true;
      allow write: if false;
    }

    // 🥡 [Pedidos] Histórico de Compras
    match /User_Orders/{orderId} {
      allow read: if request.auth != null && (
        // O usuário só lê se a matrícula no pedido for a dele
        resource.data.matricula == get(/databases/$(database)/documents/_AuthMap/$(request.auth.uid)).data.matricula
      );
      allow write: if false;
    }

    // ⚙️ [Fallback] Bloqueio preventivo para novas coleções não documentadas
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
